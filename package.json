{
  "name": "roofee",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "lint:frontend": "npm --workspace frontend run lint",
    "test:backend": "cd backend && pytest",
    "install:backend": "python3 -m venv backend/.venv && backend/.venv/bin/pip install -e 'backend[dev]'"
  }
}
